{
  "name": "podmod.app",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "cd ui && bun run build",
    "start": "bun run src/index.ts",
    "lint": "tsc --noEmit && cd ui && bun run typecheck && cd .. && prettier --check . && eslint src ui/src eslint.config.mjs",
    "prettier": "prettier --write ."
  },
  "dependencies": {
    "fast-xml-parser": "5.8.0",
    "hono": "4.12.25",
    "superjson": "2.2.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.14",
    "eslint": "10.4.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "typescript": "5.4.5",
    "typescript-eslint": "8.59.3"
  },
  "overrides": {
    "@babel/helpers": "7.28.4",
    "@babel/runtime": "7.28.4",
    "ajv": "6.15.0",
    "brace-expansion": "2.1.0",
    "braces": "3.0.3",
    "cross-spawn": "7.0.6",
    "diff": "4.0.4",
    "flatted": "3.4.2",
    "glob": "10.5.0",
    "js-yaml": "4.1.1",
    "micromatch": "4.0.8",
    "minimatch": "9.0.9",
    "nanoid": "3.3.12",
    "picomatch": "2.3.2",
    "yaml": "2.9.0"
  }
}
